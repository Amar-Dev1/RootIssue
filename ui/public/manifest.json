{
  "manifest_version": 3,
  "name": "RootIssue Extension",
  "description": "Turn Github issues into a structured implmentation plan",
  "version": "1.0.0",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "RootIssue"
  },

  "permissions": ["activeTab", "storage", "identity", "identity.email"]
}
