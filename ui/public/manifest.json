{
  "manifest_version": 3,
  "name": "RootIssue Extension",
  "description": "Turn Github issues into a structured implmentation plan",
  "version": "1.0.0",
  "action": {
    "default_popup": "index.html",
    "default_title": "RootIssue"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage"
  ]
}   